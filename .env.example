# Copie este arquivo para .env e preencha com os valores reais (sem aspas, sem espaços)

# Token JWT da API D&O / Do Sistemas (produção)
DOSISTEMAS_TOKEN=cole_seu_token_aqui

# String de conexão Postgres do Supabase (Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:[senha]@db.[ref].supabase.co:5432/postgres
