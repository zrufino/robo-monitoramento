# Copie este arquivo pra `.env` e preencha cada variável.
# O arquivo `.env` está no .gitignore — nunca vai pro GitHub.

# ============================================================
# API D&O (Verleih) — coleta de dados de estoque
# ============================================================
# Bearer token JWT da API D&O. Obter com o Rodrigo @ D&O.
DOSISTEMAS_TOKEN=

# ============================================================
# Supabase — banco de dados
# ============================================================
# Ref do projeto Supabase (ex: lnhtjcsycjhybpdwfnbd).
# Visível em https://supabase.com/dashboard → Project Settings → General.
SUPABASE_PROJECT_REF=

# Senha do usuário `postgres` (admin do banco).
# Visível em Project Settings → Database → Database Password.
SUPABASE_DB_PASSWORD=

# Connection string admin (escreve em todas as tabelas).
# Use o connection pooler (porta 5432, modo session) pra funcionar em ambientes
# IPv4-only como GitHub Actions e Streamlit Cloud.
# Formato: postgresql://postgres.<REF>:<PASS>@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Connection string read-only (role `ia_readonly`, SELECT em lista branca).
# Usada pela IA do chat. Criar com a migration 001_chat_ia.sql + GRANT manual.
# Formato: postgresql://ia_readonly.<REF>:<PASS>@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL_READONLY=

# ============================================================
# Chat IA (Gemini) — dashboard
# ============================================================
# Chave da Google AI Studio. Grátis pra uso pessoal moderado.
# Obter em https://aistudio.google.com/app/apikey
# Sem essa chave o painel chat aparece desabilitado com instruções.
GOOGLE_API_KEY=
